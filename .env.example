# JcubHub Books - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================
PORT=3003

# ===========================================
# Admin Authentication
# ===========================================
# These are used to create the default admin user on first run
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# JWT secret for token signing (auto-generated if not set)
JWT_SECRET=your-random-jwt-secret-here

# Admin email for notifications
ADMIN_EMAIL=admin@example.com

# ===========================================
# Email Configuration (Zoho Mail)
# ===========================================
ZOHO_EMAIL=your-email@zoho.com
ZOHO_PASSWORD=your-zoho-app-password

# ===========================================
# Cloudflare Turnstile (CAPTCHA)
# ===========================================
# Get these from your Cloudflare dashboard
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ===========================================
# Readarr / Chaptarr Integration
# ===========================================
# Your Readarr server URL (no trailing slash)
READARR_URL=http://localhost:8787

# Readarr API key (found in Settings > General)
READARR_API_KEY=your-readarr-api-key

# Optional: Profile/folder overrides
READARR_QUALITY_PROFILE_ID=
READARR_METADATA_PROFILE_ID=
READARR_ROOT_FOLDER=

# Optional: Format-specific profile/folder overrides
READARR_QUALITY_PROFILE_ID_EPUB=
READARR_QUALITY_PROFILE_ID_PDF=
READARR_QUALITY_PROFILE_ID_MOBI=
READARR_QUALITY_PROFILE_ID_AUDIOBOOK=
READARR_ROOT_FOLDER_EPUB=
READARR_ROOT_FOLDER_PDF=
READARR_ROOT_FOLDER_MOBI=
READARR_ROOT_FOLDER_AUDIOBOOK=

# Optional: Readarr/Chaptarr HTTP resilience
READARR_HTTP_TIMEOUT_MS=12000
READARR_HTTP_RETRIES=1
READARR_CACHE_TTL_MS=300000
READARR_FORCE_COMMAND_SEARCH=false

# ===========================================
# CWA (Calibre Web Automated) Integration
# ===========================================
# Your CWA server URL (no trailing slash)
CWA_URL=https://cwa.jcubhub.com

# CWA credentials for OPDS feed access
CWA_USERNAME=your-cwa-username
CWA_PASSWORD=your-cwa-password

# ===========================================
# Webhook Configuration
# ===========================================
# Secret key for webhook verification (optional)
WEBHOOK_SECRET=your-webhook-secret

# ===========================================
# Automation
# ===========================================
# Auto-approve requests on submit (still reviewed in admin as searching/completed)
AUTO_APPROVE=false
# Automatically send approved/new requests to Readarr/Chaptarr
AUTO_ADD_READARR=false
# Minutes between automatic CWA sync checks (0 = disabled)
AUTO_SYNC_INTERVAL=0

# ===========================================
# Optional: Send to eReader
# ===========================================
# Enable public "send to eReader" action from request status popup
EREADER_SEND_ENABLED=false
# Optional comma-separated allowlist of eReader email domains (empty = any)
# Example: kindle.com,free.kindle.com,pm.kindle.com
EREADER_ALLOWED_DOMAINS=

# ===========================================
# CORS Configuration (optional)
# ===========================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://books.jcubhub.com,http://localhost:3003
