# JcubHub Books - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================
PORT=3003

# ===========================================
# Admin Authentication
# ===========================================
# These are used to create the default admin user on first run
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# JWT secret for token signing (auto-generated if not set)
JWT_SECRET=your-random-jwt-secret-here

# Admin email for notifications
ADMIN_EMAIL=admin@example.com

# ===========================================
# Email Configuration (Zoho Mail)
# ===========================================
ZOHO_EMAIL=your-email@zoho.com
ZOHO_PASSWORD=your-zoho-app-password

# ===========================================
# Cloudflare Turnstile (CAPTCHA)
# ===========================================
# Get these from your Cloudflare dashboard
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ===========================================
# Readarr / Chaptarr Integration
# ===========================================
# Your Readarr server URL (no trailing slash)
READARR_URL=http://localhost:8787

# Readarr API key (found in Settings > General)
READARR_API_KEY=your-readarr-api-key

# ===========================================
# CWA (Calibre Web Automated) Integration
# ===========================================
# Your CWA server URL (no trailing slash)
CWA_URL=https://cwa.jcubhub.com

# CWA credentials for OPDS feed access
CWA_USERNAME=your-cwa-username
CWA_PASSWORD=your-cwa-password

# ===========================================
# Webhook Configuration
# ===========================================
# Secret key for webhook verification (optional)
WEBHOOK_SECRET=your-webhook-secret

# ===========================================
# CORS Configuration (optional)
# ===========================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://books.jcubhub.com,http://localhost:3003
